# Database
# Default local/Docker mode uses SQLite and needs no database server.
DATABASE_URL=sqlite:///data/viskit.db
VISKIT_AUTO_MIGRATE=1
VISKIT_BOOTSTRAP_WORKSPACE=1
# Max concurrent image outputs per durable generation job. Lower this if an upstream provider rate-limits.
VISKIT_GENERATION_JOB_CONCURRENCY=4

# Optional PostgreSQL mode:
# DATABASE_URL=postgresql+psycopg://viskit:viskit@localhost:5432/viskit


# Docker single-container public port and host data directory
VISKIT_WEB_PORT=3068
# Host data directory mounted to /app/data. On NAS, use e.g. /volume1/docker/viskit-studio
VISKIT_DATA_DIR=./data
# Generated images are stored under ${VISKIT_DATA_DIR}/imagegen.
# Optional Docker database override; default is sqlite:////app/data/viskit.db
# VISKIT_DATABASE_URL=sqlite:////app/data/viskit.db
# Optional Docker PostgreSQL mode. Keep commented unless you also uncomment
# the postgres service in docker-compose.yml and rebuild with UV_EXTRAS.
# UV_EXTRAS=--extra postgres
# VISKIT_DATABASE_URL=postgresql+psycopg://viskit:viskit@postgres:5432/viskit
# POSTGRES_DB=viskit
# POSTGRES_USER=viskit
# POSTGRES_PASSWORD=viskit
# VISKIT_POSTGRES_DATA_DIR=./postgres-data
# Docker default uses same-origin /api proxy; keep empty unless API is intentionally external.
NEXT_PUBLIC_API_BASE_URL=

# AI providers — values are read from environment and never stored in code.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
APIMART_API_KEY=

# Compliance screen — optional provider key for external compliance checks.
COMPLIANCE_SCREEN_API_KEY=

# Workbench
WORKBENCH_DEFAULT_LOCALE=zh
WORKBENCH_BRAND_COLOR=#C4513A
