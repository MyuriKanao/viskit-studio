{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useImportType": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  },
  "files": {
    "include": [
      "app/**",
      "components/**",
      "hooks/**",
      "lib/**",
      "scripts/**",
      "tests/**",
      "middleware.ts",
      "*.ts",
      "*.mjs"
    ],
    "ignore": [
      "components/ui/**",
      ".next/**",
      "node_modules/**",
      "playwright-report/**",
      "test-results/**"
    ]
  }
}
